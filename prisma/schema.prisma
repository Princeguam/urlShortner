// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChangeAction {
  CREATE
  UPDATE
}

enum Role {
  ADMIN
  USER
}

enum TokenType {
  EmailVerification
  PasswordReset
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum TransactionStatus {
  INITIATED
  SUCCESS
  FAILED
}

enum PlanType {
  Free
  Basic
  Pro
}

enum BillingCycle {
  Monthly
  Annually
}

model Users {
  Id            Int      @id @default(autoincrement())
  Username      String
  Email         String
  Password      String
  Role          Role     @default(USER)
  Created       DateTime @default(now())
  Updated       DateTime @updatedAt()
  EmailVerified Boolean  @default(false)

  UserSession  UserSessions[]
  History      History[]
  Url          Urls[]
  UserToken    UserToken[]
  Payment      Payments[]
  Subscription Subscription[]

  @@unique([Email, Password])
  @@index([Username, Email])
}

model UserToken {
  Id         Int       @id @default(autoincrement())
  UserId     Int
  Token      String    @unique
  Expiration DateTime
  Type       TokenType
  UsedAt     DateTime?
  Created    DateTime  @default(now())
  Updated    DateTime  @updatedAt

  User Users @relation(fields: [UserId], references: [Id], onDelete: Cascade)
}

model UserSessions {
  Id           String   @id @default(uuid())
  UserId       Int
  RefreshToken String
  Expiration   DateTime
  Created      DateTime @default(now())
  Updated      DateTime @updatedAt()

  User Users @relation(fields: [UserId], references: [Id], onDelete: Cascade)
}

model Urls {
  Id        Int      @id @default(autoincrement())
  UserId    Int
  LongUrl   String
  ShortUrl  String?
  IsActive  Boolean?
  Clicks    Int?     @default(0)
  ExpiresAt DateTime
  Created   DateTime @default(now())
  Updated   DateTime @updatedAt

  CreatedBy Users       @relation(fields: [UserId], references: [Id], onDelete: Cascade)
  ClickLog  ClickLogs[]
  History   History[]
}

model History {
  Id              Int          @id @default(autoincrement())
  ChangedById     Int
  UrlId           Int
  Action          ChangeAction @default(UPDATE)
  PreviousLongUrl String?
  NewLongUrl      String
  changedAt       DateTime     @default(now())

  ChangedBy Users @relation(fields: [ChangedById], references: [Id])
  Url       Urls  @relation(fields: [UrlId], references: [Id], onDelete: Cascade)
}

model ClickLogs {
  Id        Int     @id @default(autoincrement())
  UrlId     Int
  IpAddress String?
  UserAgent String?

  Created DateTime @default(now())

  Url Urls @relation(fields: [UrlId], references: [Id], onDelete: Cascade)
}

model Plan {
  Id          String   @id @default(uuid())
  Name        PlanType @unique
  Price       Decimal // monthly price
  AnnualPrice Decimal? // discounted annual price
  MaxUrls     Int? // how many short urls allowed
  MaxClicks   Int? // click limit per month
  CustomSlug  Boolean? @default(false) // custom short codes
  Analytics   Boolean  @default(false) // access to click analytics
  Created     DateTime @default(now())
  Updated     DateTime @updatedAt

  Subscriptions Subscription[]
}

model Subscription {
  Id           String       @id @default(uuid())
  UserId       Int
  PlanId       String
  BillingCycle BillingCycle
  IsActive     Boolean      @default(false)
  StartDate    DateTime?
  EndDate      DateTime? // null = active until cancelled
  Created      DateTime     @default(now())
  Updated      DateTime     @updatedAt

  User     Users      @relation(fields: [UserId], references: [Id])
  Plan     Plan       @relation(fields: [PlanId], references: [Id])
  Payments Payments[]
}

model Payments {
  Id             String        @id @default(uuid())
  UserId         Int
  SubscriptionId String
  Amount         Decimal
  Currency       String        @default("NGN")
  Status         PaymentStatus @default(PENDING)

  // Paystack specific fields
  Reference       String    @unique // your generated reference sent to paystack
  Description     String?
  PaystackRef     String?   @unique // paystack's own reference
  PaystackChannel String? // card, bank, ussd etc
  PaidAt          DateTime?

  Created DateTime @default(now())
  Updated DateTime @updatedAt

  User         Users        @relation(fields: [UserId], references: [Id])
  Subscription Subscription @relation(fields: [SubscriptionId], references: [Id])
}
